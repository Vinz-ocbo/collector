# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=info

# Scryfall
SCRYFALL_BASE_URL=https://api.scryfall.com
SCRYFALL_USER_AGENT=TCGCollector/0.1.0 (dev contact: noreply@tcg-collector.local)
SCRYFALL_RATE_LIMIT_PER_SECOND=8

# Database — optional. When set, the proxy can fall back to local DB and the
# bulk-ingest admin endpoint becomes available. Required to run drizzle-kit.
# DATABASE_URL=postgresql://tcgcollector:dev@localhost:5432/tcgcollector

# Admin endpoint bearer token — required to call POST /admin/* routes.
# ADMIN_TOKEN=change-me
