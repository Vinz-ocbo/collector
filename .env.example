# Backend API base URL (Scryfall proxy + auth + collection sync).
# Default: http://localhost:3001 (the local Fastify proxy). Leave empty to
# fall back to the in-browser mock backend (searches the local Dexie cards
# table, no network calls — useful when working without the backend running).
VITE_API_BASE_URL=http://localhost:3001

# Sentry (frontend error reporting) — optional in dev
VITE_SENTRY_DSN=
